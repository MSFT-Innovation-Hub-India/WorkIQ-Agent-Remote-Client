# --------------------------------------------------------------------------
# WorkIQ Teams Relay Bot — Environment Configuration
# --------------------------------------------------------------------------

# Entra Tenant ID of your Azure (FDPO) subscription where Bot Service,
# Container App, and Redis are deployed
TENANT_ID="<your-azure-tenant-id>"

# Entra Tenant ID of the CORP tenant where Teams users reside
HOST_TENANT_ID="<your-corp-tenant-id>"

# Entra Application (Client) ID and Secret of the Bot App Registration
CLIENT_ID="<your-bot-app-client-id>"
CLIENT_SECRET="<your-bot-app-client-secret>"

# Azure Managed Redis endpoint (host:port, SSL on port 10000)
AZ_REDIS_CACHE_ENDPOINT="<your-redis-host>:<port>"

# Port the bot server listens on (default 3978)
PORT=3978

# Log level
LOG_LEVEL="INFO"
